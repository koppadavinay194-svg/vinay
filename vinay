  </div>

  <div class="hero-actions">
    <a href="#work" data-scroll="work" class="btn btn-primary">View my work ↓</a>
    <a href="#contact" data-scroll="contact" class="btn btn-ghost">Get in touch</a>
  </div>
</section>

<!-- ================= WORK / GALLERY ================= -->
<section id="work">
  <div class="sec-head reveal">
    <span class="stamp-num mono">01</span>
    <h2>Selected Work</h2>
    <span class="rule"></span>
  </div>

  <div class="filters reveal">
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="poster">Posters</button>
    <button class="filter-btn" data-filter="flyer">Flyers</button>
    <button class="filter-btn" data-filter="brochure">Brochures &amp; Menus</button>
  </div>

  <div class="gallery">

    <div class="gcard reveal" data-cat="flyer">
      <div class="gthumb" data-full="data:image/jpeg;base64," data-cap="Nexora Solutions — corporate flyer">
        <img src="data:image/jpeg;base64," alt="Nexora Solutions corporate flyer">
      </div>
      <div class="gcard-body">
        <span class="gtag mono">Flyer</span>
        <h3>Nexora Solutions</h3>
        <p>Corporate services flyer with a bold split layout, service list, and trust stats for a business consultancy.</p>
      </div>
    </div>

    <div class="gcard reveal" data-cat="flyer">
      <div class="gthumb" data-full="data:image/jpeg;base64," data-cap="Fit Zone Club — gym flyer">
        <img src="data:image/jpeg;base64," alt="Fit Zone Club gym flyer">
      </div>
      <div class="gcard-body">
        <span class="gtag mono">Flyer</span>
        <h3>Fit Zone Club</h3>
        <p>High-contrast fitness flyer built around a hero photo, program breakdown, and a limited-time offer callout.</p>
      </div>
    </div>

    <div class="gcard reveal" data-cat="poster">
      <div class="gthumb" data-full="data:image/jpeg;base64," data-cap="Budweiser — product poster">
        <img src="data:image/jpeg;base64," alt="Budweiser product poster">
      </div>
      <div class="gcard-body">
        <span class="gtag mono">Poster</span>
        <h3>Budweiser</h3>
        <p>Product-hero poster using oversized wordmark type behind the bottle, wheat and splash accents, warm gold tones.</p>
      </div>
    </div>

    <div class="gcard reveal" data-cat="brochure">
      <div class="gthumb" data-full="data:image/jpeg;base64," data-cap="Restaurant tri-panel menu">
        <img src="data:image/jpeg;base64," alt="Restaurant non-veg menu design">
      </div>
      <div class="gcard-body">
        <span class="gtag mono">Menu · Brochure</span>
        <h3>Restaurant Menu</h3>
        <p>Full restaurant menu spanning breakfast, mains, Chinese, and biryani sections, organised into clean price columns.</p>
      </div>
    </div>

    <div class="gcard reveal" data-cat="poster">
      <div class="gthumb" data-full="data:image/jpeg;base64," data-cap="Dave Drinks — Mango poster">
        <img src="data:image/jpeg;base64," alt="Mango juice poster">
      </div>
      <div class="gcard-body">
        <span class="gtag mono">Poster</span>
        <h3>Dave Drinks — Mango</h3>
        <p>Split-colour poster with vertical rotated type and a dynamic juice splash to sell a single flavour hard.</p>
      </div>
    </div>

    <div class="gcard reveal" data-cat="brochure">
      <div class="gthumb" data-full="data:image/jpeg;base64," data-cap="Healthy Eating — food menu">
        <img src="data:image/jpeg;base64," alt="Healthy Eating food menu design">
      </div>
      <div class="gcard-body">
        <span class="gtag mono">Menu · Brochure</span>
        <h3>Healthy Eating Food Menu</h3>
        <p>Dark, photo-led menu for burgers, sandwiches and pizza, using torn arrows and callouts to guide the eye.</p>
      </div>
    </div>

    <div class="gcard reveal" data-cat="flyer">
      <div class="gthumb" data-full="data:image/jpeg;base64," data-cap="Delicious Food Menu — fast food flyer">
        <img src="data:image/jpeg;base64," alt="Delicious food menu fast food flyer">
      </div>
      <div class="gcard-body">
        <span class="gtag mono">Flyer</span>
        <h3>Fast Food Delivery Flyer</h3>
        <p>Diagonal two-tone flyer promoting free delivery and a 50% offer, anchored by a single hero food shot.</p>
      </div>
    </div>

    <div class="gcard reveal" data-cat="poster">
      <div class="gthumb" data-full="data:image/jpeg;base64," data-cap="G:N Long Drink — Lemon Soda poster">
        <img src="data:image/jpeg;base64," alt="Lemon soda poster">
      </div>
      <div class="gcard-body">
        <span class="gtag mono">Poster</span>
        <h3>G:N Long Drink — Lemon Soda</h3>
        <p>Bright, saturated product poster combining a splash composition with the can as the clear focal point.</p>
      </div>
    </div>

  </div>
</section>

<!-- ================= SKILLS ================= -->
