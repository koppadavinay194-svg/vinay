<!-- ================= LIGHTBOX ================= -->
<div id="lightbox">
  <button id="lb-close" aria-label="Close">✕</button>
  <img id="lb-img" src="" alt="">
  <div class="lb-cap mono" id="lb-cap"></div>
</div>

<script>
  // ---- scroll nav ----
  const navLinks = document.querySelectorAll('nav a, [data-scroll]');
  navLinks.forEach(l=>{
    l.addEventListener('click', (e)=>{
      const id = l.dataset.scroll;
      if(id){
        e.preventDefault();
        document.getElementById(id)?.scrollIntoView({behavior:'smooth'});
      }
    });
  });

  const sectionIds = ['hero','work','skills','about','contact'];
  const navA = document.querySelectorAll('nav a');
  function onScrollNav(){
    let current = sectionIds[0];
    sectionIds.forEach(id=>{
      const el = document.getElementById(id);
      if(el && el.getBoundingClientRect().top < window.innerHeight*0.4) current = id;
    });
    navA.forEach(a=> a.classList.toggle('active', a.dataset.scroll === current));
  }
  window.addEventListener('scroll', onScrollNav, {passive:true});
  onScrollNav();

  // ---- reveal on scroll ----
  const revealEls = document.querySelectorAll('.reveal, .gcard');
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(entry=>{
      if(entry.isIntersecting){
        entry.target.classList.add('in');
        if(entry.target.classList.contains('gcard')) entry.target.classList.add('in');
        io.unobserve(entry.target);
      }
    });
  }, {threshold:0.12});
  revealEls.forEach(el=>{ el.classList.add('reveal'); io.observe(el); });

  // ---- skill bars fill on view ----
  const bars = document.querySelectorAll('.layer-bar');
  const barIo = new IntersectionObserver((entries)=>{
    entries.forEach(entry=>{
      if(entry.isIntersecting){
        entry.target.style.width = entry.target.dataset.pct + '%';
        barIo.unobserve(entry.target);
      }
    });
  }, {threshold:0.4});
  bars.forEach(b=> barIo.observe(b));

  // ---- gallery filter ----
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.gcard');
  filterBtns.forEach(btn=>{
    btn.addEventListener('click', ()=>{
      filterBtns.forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      const f = btn.dataset.filter;
      cards.forEach(c=>{
        c.classList.toggle('hide', f !== 'all' && c.dataset.cat !== f);
      });
    });
  });

  // ---- lightbox ----
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbCap = document.getElementById('lb-cap');
  document.querySelectorAll('.gthumb').forEach(th=>{
    th.addEventListener('click', ()=>{
      lbImg.src = th.dataset.full;
      lbCap.textContent = th.dataset.cap || '';
      lightbox.classList.add('open');
    });
  });
  function closeLb(){ lightbox.classList.remove('open'); }
  document.getElementById('lb-close').addEventListener('click', closeLb);
  lightbox.addEventListener('click', (e)=>{ if(e.target === lightbox) closeLb(); });
  document.addEventListener('keydown', (e)=>{ if(e.key === 'Escape') closeLb(); });
</script>

