<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vinay Koppada — Graphic Designer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#131212;
    --paper-2:#1B1A19;
    --card:#1F1D1C;
    --cream:#F3EEE3;
    --dim:#9C968A;
    --red:#E8402A;
    --gold:#D9A441;
    --line:#332F2B;
    --radius:3px;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:
      radial-gradient(ellipse at top left, rgba(232,64,42,.06), transparent 60%),
      var(--paper);
    color:var(--cream);
    font-family:'Inter', sans-serif;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  ::selection{background:var(--red); color:var(--cream);}
  a{color:inherit;}
  img{display:block; max-width:100%;}
  .mono{font-family:'JetBrains Mono', monospace;}
  .display{font-family:'Anton', sans-serif;}

  /* ============ REVEAL ANIMATION ============ */
  .reveal{
    opacity:0; transform:translateY(28px);
    transition:opacity .7s cubic-bezier(.16,.8,.3,1), transform .7s cubic-bezier(.16,.8,.3,1);
  }
  .reveal.in{opacity:1; transform:translateY(0);}

  /* ============ NAV ============ */
  header{
    position:fixed; top:0; left:0; right:0; z-index:60;
    display:flex; align-items:center; justify-content:space-between;
    padding:20px 44px;
    background:rgba(19,18,18,.85); backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line);
  }
  @media (max-width:780px){ header{padding:16px 20px;} }
  .logo{
    display:flex; align-items:center; gap:10px;
    font-family:'Anton', sans-serif; font-size:19px; letter-spacing:.02em;
  }
  .logo .mark{
    width:30px; height:30px; border:1.5px solid var(--red); border-radius:50%;
    display:flex; align-items:center; justify-content:center; font-family:'JetBrains Mono',monospace;
    font-size:11px; color:var(--red); transform:rotate(-8deg);
  }
  nav ul{list-style:none; display:flex; gap:30px;}
  nav a{
    text-decoration:none; color:var(--dim); font-size:12px; font-weight:600;
    text-transform:uppercase; letter-spacing:.09em; position:relative; padding-bottom:3px;
    transition:color .2s ease; cursor:pointer;
  }
  nav a::after{content:"";position:absolute; left:0; bottom:0; width:0; height:1px; background:var(--red); transition:width .25s ease;}
  nav a:hover, nav a.active{color:var(--cream);}
  nav a:hover::after, nav a.active::after{width:100%;}
  #menu-btn{display:none;}
  @media (max-width:780px){ nav ul{display:none;} #menu-btn{display:block; background:none; border:1px solid var(--line); color:var(--cream); font-size:11px; padding:8px 12px;} }

  main{padding-top:88px;}
  section{padding:100px 44px 20px; max-width:1320px; margin:0 auto; position:relative;}
  @media (max-width:780px){ section{padding:80px 20px 10px;} }

  .sec-head{display:flex; align-items:baseline; gap:16px; margin-bottom:48px;}
  .sec-head .stamp-num{
    font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--red);
    border:1px solid var(--red); padding:3px 9px; border-radius:20px;
  }
  .sec-head h2{
    font-family:'Anton', sans-serif; font-size:clamp(22px,3.4vw,34px); text-transform:uppercase; letter-spacing:.01em;
  }
  .sec-head .rule{flex:1; height:1px; background:var(--line);}

  /* ============ HERO ============ */
  #hero{ min-height:92vh; display:flex; flex-direction:column; justify-content:center; padding-top:150px; }
  .hero-kicker{
    display:inline-flex; align-items:center; gap:8px; width:max-content;
    font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--gold);
    margin-bottom:26px; opacity:0; animation:fadeUp .7s ease .1s forwards;
  }
  .hero-kicker .sq{width:6px;height:6px;background:var(--gold);}

  h1.hero-title{
    font-family:'Anton', sans-serif; text-transform:uppercase;
    font-size:clamp(2.8rem, 9vw, 7.2rem); line-height:.92; letter-spacing:.005em;
  }
  h1.hero-title span{display:block; overflow:hidden;}
  h1.hero-title span b{
    display:block; font-weight:400; opacity:0; transform:translateY(100%);
    animation:slideUp .8s cubic-bezier(.16,.8,.3,1) forwards;
  }
  h1.hero-title .l1 b{animation-delay:.15s;}
  h1.hero-title .l2 b{animation-delay:.3s; color:var(--red);}
  @keyframes slideUp{to{opacity:1; transform:translateY(0);}}
  @keyframes fadeUp{from{opacity:0; transform:translateY(14px);} to{opacity:1; transform:translateY(0);}}

  .hero-sub{
    margin-top:28px; font-size:17.5px; color:var(--dim); max-width:54ch; line-height:1.65;
    opacity:0; animation:fadeUp .7s ease .55s forwards;
  }
  .hero-sub strong{color:var(--cream); font-weight:600;}

  .hero-meta{ margin-top:42px; display:flex; gap:38px; flex-wrap:wrap; opacity:0; animation:fadeUp .7s ease .7s forwards; }
  .hero-meta div{font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--dim); text-transform:uppercase; letter-spacing:.06em;}
  .hero-meta strong{display:block; font-family:'Inter',sans-serif; font-size:15px; color:var(--cream); font-weight:600; margin-top:5px; text-transform:none; letter-spacing:0;}
  .hero-meta a{text-decoration:none; border-bottom:1px solid transparent;}
  .hero-meta a:hover{border-color:var(--red); color:var(--red);}

  .hero-actions{margin-top:46px; display:flex; gap:16px; flex-wrap:wrap; opacity:0; animation:fadeUp .7s ease .85s forwards;}
  .btn{
    font-family:'JetBrains Mono',monospace; font-size:13px; padding:14px 24px; border-radius:2px;
    text-decoration:none; display:inline-flex; align-items:center; gap:8px; transition:all .25s ease;
  }
  .btn-primary{background:var(--red); color:var(--cream); border:1px solid var(--red); font-weight:700;}
  .btn-primary:hover{background:transparent; color:var(--red); transform:translateY(-2px);}
  .btn-ghost{border:1px solid var(--line); color:var(--cream);}
  .btn-ghost:hover{border-color:var(--cream); transform:translateY(-2px);}

  .stamp{
    position:absolute; right:44px; top:130px; width:118px; height:118px;
    border:2px solid var(--red); border-radius:50%; transform:rotate(-10deg);
    display:flex; align-items:center; justify-content:center; text-align:center;
    font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--red);
    opacity:0; animation:stampIn .5s ease .95s forwards, floaty 5s ease-in-out 1.5s infinite;
  }
  .stamp::before{
    content:""; position:absolute; inset:8px; border:1px solid var(--red); border-radius:50%; opacity:.5;
  }
  @keyframes stampIn{from{opacity:0; transform:rotate(-10deg) scale(1.6);} to{opacity:1; transform:rotate(-10deg) scale(1);}}
  @keyframes floaty{0%,100%{transform:rotate(-10deg) translateY(0);} 50%{transform:rotate(-10deg) translateY(-6px);}}
  @media (max-width:900px){ .stamp{display:none;} }

  /* ============ FILTER TABS ============ */
  .filters{display:flex; gap:12px; flex-wrap:wrap; margin-bottom:44px;}
  .filter-btn{
    font-family:'JetBrains Mono',monospace; font-size:12px; padding:9px 18px; border-radius:20px;
    border:1px solid var(--line); background:transparent; color:var(--dim); cursor:pointer;
    transition:all .2s ease;
  }
  .filter-btn:hover{border-color:var(--cream); color:var(--cream);}
  .filter-btn.active{background:var(--red); border-color:var(--red); color:var(--cream);}

  /* ============ GALLERY ============ */
  .gallery{
    columns:3 320px; column-gap:24px;
  }
  @media (max-width:700px){ .gallery{columns:1 320px;} }
  .gcard{
    break-inside:avoid; margin-bottom:24px; background:var(--card); border:1px solid var(--line);
    border-radius:var(--radius); overflow:hidden; position:relative;
    transition:transform .35s cubic-bezier(.16,.8,.3,1), border-color .3s ease, box-shadow .35s ease;
  }
  .gcard:hover{ transform:translateY(-6px); border-color:var(--red); box-shadow:0 22px 40px -20px rgba(0,0,0,.6); }
  .gcard.hide{display:none;}
  .gthumb{position:relative; overflow:hidden; cursor:pointer;}
  .gthumb img{width:100%; display:block; transition:transform .5s ease;}
  .gcard:hover .gthumb img{transform:scale(1.05);}
  .gthumb::after{
    content:"VIEW"; position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
    background:rgba(19,18,18,0); color:var(--cream); font-family:'JetBrains Mono',monospace; font-size:12px;
    letter-spacing:.15em; opacity:0; transition:all .3s ease;
  }
  .gthumb:hover::after{background:rgba(19,18,18,.45); opacity:1;}
  .gcard-body{padding:16px 18px 20px;}
  .gtag{
    display:inline-block; font-family:'JetBrains Mono',monospace; font-size:9.5px; color:var(--gold);
    text-transform:uppercase; letter-spacing:.08em; border:1px solid var(--gold); padding:3px 8px; border-radius:20px;
    margin-bottom:10px;
  }
  .gcard h3{font-family:'Anton', sans-serif; font-size:16px; text-transform:uppercase; letter-spacing:.01em; margin-bottom:6px;}
  .gcard p{font-size:12.5px; color:var(--dim); line-height:1.5;}

  /* ============ LIGHTBOX ============ */
  #lightbox{
    position:fixed; inset:0; background:rgba(10,9,9,.94); z-index:100;
    display:none; align-items:center; justify-content:center; padding:40px;
    opacity:0; transition:opacity .25s ease;
  }
  #lightbox.open{display:flex; opacity:1;}
  #lightbox img{max-width:90vw; max-height:82vh; border-radius:3px; box-shadow:0 30px 60px rgba(0,0,0,.6);}
  #lightbox .lb-cap{
    position:absolute; bottom:34px; left:0; right:0; text-align:center;
    font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--dim);
  }
  #lb-close{
    position:absolute; top:28px; right:36px; background:none; border:1px solid var(--line); color:var(--cream);
    width:38px; height:38px; border-radius:50%; cursor:pointer; font-size:16px;
  }
  #lb-close:hover{border-color:var(--red); color:var(--red);}

  /* ============ SKILLS ============ */
  .layers{display:flex; flex-direction:column; gap:1px; background:var(--line); border:1px solid var(--line); border-radius:var(--radius); overflow:hidden;}
  .layer-row{background:var(--card); display:flex; align-items:center; gap:16px; padding:14px 20px;}
  .layer-swatch{width:14px; height:14px; border-radius:3px; flex-shrink:0;}
  .layer-name{font-weight:600; font-size:14px; min-width:210px;}
  .layer-bar-bg{flex:1; height:6px; background:var(--paper-2); border-radius:4px; overflow:hidden;}
  .layer-bar{height:100%; border-radius:4px; width:0; transition:width 1.1s cubic-bezier(.16,.8,.3,1);}
  .layer-pct{font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--dim); width:40px; text-align:right;}

  /* ============ ABOUT ============ */
  .about-wrap{display:grid; grid-template-columns:1.1fr .9fr; gap:60px; align-items:start;}
  @media (max-width:900px){ .about-wrap{grid-template-columns:1fr; gap:34px;} }
  .about-wrap p{font-size:17px; line-height:1.75; color:var(--dim); margin-bottom:18px;}
  .about-wrap p strong{color:var(--cream); font-weight:600;}
  .stat-grid{display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--line); border:1px solid var(--line);}
  .stat{background:var(--card); padding:26px 22px;}
  .stat .n{font-family:'Anton', sans-serif; font-size:32px; color:var(--red);}
  .stat .l{font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--dim); text-transform:uppercase; margin-top:6px; letter-spacing:.05em;}

  /* ============ CONTACT ============ */
  #contact{
    background:var(--card); border:1px solid var(--line); border-radius:6px;
    margin:0 44px 100px; padding:70px 56px; max-width:none;
  }
  @media (max-width:780px){ #contact{margin:0 20px 60px; padding:50px 24px;} }
  #contact h3{
    font-family:'Anton', sans-serif; font-size:clamp(1.9rem,4.8vw,3.4rem); text-transform:uppercase; line-height:1.05; max-width:18ch;
  }
  #contact h3 .accent{color:var(--red);}
  .render-panel{margin-top:44px; display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--line); border:1px solid var(--line);}
  @media (max-width:780px){ .render-panel{grid-template-columns:1fr;} }
  .render-item{background:var(--paper); padding:26px 24px;}
  .render-item .k{font-family:'JetBrains Mono',monospace; font-size:10px; color:var(--dim); text-transform:uppercase; letter-spacing:.06em;}
  .render-item .v{margin-top:10px; font-size:17px; font-weight:600;}
  .render-item .v a{text-decoration:none;}
  .render-item .v a:hover{color:var(--red);}

  footer{
    padding:26px 44px 46px; display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px;
    font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--dim);
    max-width:1320px; margin:0 auto;
  }
  @media (max-width:780px){ footer{padding:20px 20px 34px;} }

  @media (prefers-reduced-motion: reduce){
    html{scroll-behavior:auto;}
    *{animation:none !important; transition:none !important;}
    .reveal{opacity:1; transform:none;}
    h1.hero-title span b{opacity:1; transform:none;}
  }
  :focus-visible{outline:2px solid var(--red); outline-offset:2px;}
</style>
</head>
<body>

<header>
  <div class="logo"><span class="mark">VK</span>Vinay Koppada</div>
  <nav>
    <ul>
      <li><a data-scroll="hero" class="active">Home</a></li>
