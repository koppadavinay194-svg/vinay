      <span class="layer-swatch" style="background:#8C6BFF;"></span>
      <span class="layer-name">Illustrator vector work</span>
      <span class="layer-bar-bg"><span class="layer-bar" data-pct="82" style="background:#8C6BFF;"></span></span>
      <span class="layer-pct mono">82%</span>
    </div>
